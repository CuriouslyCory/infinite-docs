// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Prisma 7: the connection URL lives in prisma.config.ts (CLI/Migrate) and
    // is passed to PrismaClient via the driver adapter at runtime (see src/server/db.ts).
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    projects      Project[]
}

// Root container of one architecture graph (see CONTEXT.md).
// Addressed by an unguessable capability-URL `slug`; owned by a single User.
model Project {
    id        String    @id @default(cuid())
    title     String
    slug      String    @unique
    ownerId   String
    owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?
    nodes     Node[]
    edges     Edge[]

    @@index([ownerId])
}

// Cosmetic category of a Component: drives only its icon/color, never behaviour
// or authorization (see CONTEXT.md "Component kind"). Mirrored by the Zod enum
// `nodeKind` in ~/lib/schemas, which is the client-safe source of truth; a
// compile-time parity guard in the service layer keeps the two in lockstep.
enum NodeKind {
    GENERIC
    SERVICE
    DATABASE
    EXTERNAL_API
    HOST
    QUEUE
}

// Cosmetic orientation of a Connection: drives only how it is drawn (no
// arrowhead / one / two), never behaviour or de-duplication (see CONTEXT.md
// "Edge direction"). Mirrored by the Zod enum `edgeDirection` in ~/lib/schemas,
// the client-safe source of truth; a compile-time parity guard in edge.service
// keeps the two in lockstep.
enum EdgeDirection {
    NONE
    FORWARD
    BIDIRECTIONAL
}

// The data-model representation of a Component (see CONTEXT.md "Component / Node
// split"); never surfaced to users by this name. Nests via `parentId`: null is
// the Project's root Canvas, otherwise the id of the containing Component whose
// interior Canvas this Node sits on. The FK cascades are the hard-delete
// backstop only — the normal removal path is soft-delete via `deletedAt` (PRD).
model Node {
    id            String    @id @default(cuid())
    projectId     String
    project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    parentId      String?
    parent        Node?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
    children      Node[]    @relation("NodeChildren")
    title         String
    kind          NodeKind  @default(GENERIC)
    posX          Float     @default(0)
    posY          Float     @default(0)
    documentation String    @default("")
    metadata      Json?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    deletedAt     DateTime?

    // Edges are scoped to a Canvas by an explicit `canvasNodeId` and reference
    // their endpoints by `sourceId`/`targetId`; three relations to one model
    // force Prisma's named-relation disambiguation (see ADR-0005).
    edgesOnCanvas Edge[]    @relation("EdgesOnCanvas")
    outgoingEdges Edge[]    @relation("EdgesFromNode")
    incomingEdges Edge[]    @relation("EdgesToNode")

    @@index([projectId, parentId])
    @@index([parentId])
}

// The data-model representation of a Connection (see CONTEXT.md "Connection /
// Edge split"); never surfaced to users by this name. Its Canvas is the
// EXPLICIT `canvasNodeId` (the Component whose interior Canvas owns it; null =
// the Project root) — recorded, NOT inferred from the endpoints, so a future
// refinement Connection can legitimately span scope levels (ADR-0005). The
// three invariants — both endpoints on the same Canvas, no self-link, and no
// duplicate ACTIVE Edge sharing source+target+scope — are enforced in
// `connectNodes`, NOT by database constraints: do not add an `@@unique` here
// (it would also wrongly forbid re-creating a soft-deleted Connection;
// ADR-0005). The FK cascades are the hard-delete backstop only — the normal
// removal path is soft-delete via `deletedAt`. `label` is untrusted user
// content; `direction` is cosmetic (CONTEXT.md "Edge direction").
model Edge {
    id           String        @id @default(cuid())
    projectId    String
    project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
    canvasNodeId String?
    canvasNode   Node?         @relation("EdgesOnCanvas", fields: [canvasNodeId], references: [id], onDelete: Cascade)
    sourceId     String
    source       Node          @relation("EdgesFromNode", fields: [sourceId], references: [id], onDelete: Cascade)
    targetId     String
    target       Node          @relation("EdgesToNode", fields: [targetId], references: [id], onDelete: Cascade)
    label        String?
    direction    EdgeDirection @default(FORWARD)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    deletedAt    DateTime?

    @@index([projectId, canvasNodeId])
    @@index([sourceId])
    @@index([targetId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
