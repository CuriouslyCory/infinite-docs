// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Prisma 7: the connection URL lives in prisma.config.ts (CLI/Migrate) and
    // is passed to PrismaClient via the driver adapter at runtime (see src/server/db.ts).
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    projects      Project[]
    apiTokens     ApiToken[]
    memberships   ProjectMembership[]
}

// Root container of one architecture graph (see CONTEXT.md).
// Addressed by an unguessable capability-URL `slug`; owned by a single User.
model Project {
    id          String      @id @default(cuid())
    title       String
    slug        String      @unique
    ownerId     String
    owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    // The capability granted to an ANONYMOUS holder of the capability-URL slug
    // (ADR-0040): VIEW reproduces ADR-0002's slug-read model (the default; the
    // backfill that keeps every existing Project public-readable), NONE closes
    // anonymous reads to members only. The owner is never a row here â€” ownership
    // is the `ownerId` identity check, the irrevocable root of trust (ADR-0002).
    guestAccess GuestAccess @default(VIEW)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    deletedAt   DateTime?
    nodes       Node[]
    edges       Edge[]
    specs       Spec[]
    traces      Trace[]
    memberships ProjectMembership[]
    invites     ProjectInvite[]
    // The portal Components (in OTHER Projects) that embed this Project (#119).
    // `onDelete: SetNull` on the FK side leaves those portals as harmless dangling
    // shells when this Project is hard-deleted, never cascading into the host graph.
    embeddedBy  Node[]      @relation("EmbeddedProjects")
    // The cross-project Connections ANCHORED in this Project as host (#122). The
    // host FK cascades on hard-delete; the FOREIGN endpoint is a loose String
    // column on CrossProjectEdge (no relation here), so a foreign delete never
    // cascades into the host graph.
    crossProjectEdges CrossProjectEdge[] @relation("CrossEdgeHostProject")

    @@index([ownerId])
}

// The capability granted to an anonymous holder of a Project's capability-URL
// slug (CONTEXT.md "Guest access"; ADR-0040). VIEW is ADR-0002's classic
// slug-read (the @default, so existing rows backfill to it and the slice is
// behavior-neutral); NONE makes the Project members-only without rotating the
// slug. Never exceeds `view` â€” the slug is never a write grant.
enum GuestAccess {
    NONE
    VIEW
}

// The named, persisted level a Member holds on a Project (CONTEXT.md "Role";
// ADR-0040). Maps onto the capability ladder in `access.ts`: VIEWER -> view,
// EDITOR -> edit, ADMIN -> admin (still strictly below owner). There is no
// assignable OWNER or NONE role â€” owner is the `ownerId` identity, "none" is the
// absence of a grant. Distinct from API-token `scopes` (stored-not-enforced,
// ADR-0021): a Role rank IS enforced at the access seam.
enum ProjectRole {
    VIEWER
    EDITOR
    ADMIN
}

// A grant of a Role to a User on a Project (CONTEXT.md "Member"; ADR-0040). One
// grade per (project, user) via the composite unique; the @@index([userId])
// serves the "projects I'm a member of" direction (#109). The owner is NEVER a
// membership row â€” ownership is `Project.ownerId`, the irrevocable root of trust
// (ADR-0002), so no operation auto-inserts an owner membership. Both FKs cascade:
// dropping the Project or the User drops the grant.
model ProjectMembership {
    id        String      @id @default(cuid())
    projectId String
    project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
    userId    String
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    role      ProjectRole
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt

    @@unique([projectId, userId])
    @@index([userId])
}

// A role-bearing bearer link that grants a Role on redemption (CONTEXT.md
// "Invite"; ADR-0040). The system's THIRD bearer secret after the slug and the
// API token, and it inherits the API token's storage posture wholesale
// (ADR-0020): the raw token is shown once and stored only as a keyed HMAC
// (`tokenHash`, unique for lookup), with a non-secret `prefix` for display and
// `keyVersion` selecting the pepper. Project-scoped (no userId â€” an invite is
// consumed by whoever redeems it). The table lands now (ahead of its #106
// redemption consumer) so the full sharing data model arrives in one migration;
// the redemption service is a later slice.
model ProjectInvite {
    id         String      @id @default(cuid())
    projectId  String
    project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
    tokenHash  String      @unique
    prefix     String
    keyVersion Int         @default(1)
    role       ProjectRole
    expiresAt  DateTime?
    revokedAt  DateTime?
    maxUses    Int?
    useCount   Int         @default(0)
    createdAt  DateTime    @default(now())

    @@index([projectId])
}

// A bearer credential a signed-in user mints so an AI agent can call the system
// as that user over the MCP path (see CONTEXT.md "API token"; ADR-0020). The
// raw token is shown exactly once at mint and NEVER persisted or logged â€” only
// its keyed HMAC (`tokenHash`, unique for lookup) and a non-secret `prefix` for
// display are stored. `keyVersion` selects which server pepper keyed the hash,
// so the pepper can be rotated without a hash migration. `scopes` are stored but
// NOT enforced â€” authorization derives only from the owning user (ADR-0001,
// ADR-0021). Revocation is soft (`revokedAt`), keeping the prefix/audit trail.
// Token -> Actor resolution is the consumer side (#18), not modelled here.
model ApiToken {
    id         String    @id @default(cuid())
    userId     String
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    label      String?
    tokenHash  String    @unique
    prefix     String
    keyVersion Int       @default(1)
    scopes     String[]
    createdAt  DateTime  @default(now())
    expiresAt  DateTime?
    revokedAt  DateTime?

    @@index([userId])
}

// Cosmetic category of a Component: drives only its icon/color and the kind
// affinity ranking the picker offers, never behaviour or authorization (see
// CONTEXT.md "Component kind"; ADR-0018). The value set spans the hierarchy the
// tool documents â€” global infrastructure down to individual code branches â€” and
// stays additive: a new kind is one enum row plus one label + icon, never a
// code-path branch. Mirrored by the Zod enum `nodeKind` in ~/lib/schemas, which
// is the client-safe source of truth; a compile-time parity guard in the service
// layer keeps the two in lockstep.
enum NodeKind {
    GENERIC
    // Global / regional
    GLOBAL_INFRA
    REGION
    // Physical / network
    DATACENTER
    NETWORK
    HOST
    // Runtime
    CONTAINER
    SERVICE
    MICROSERVICE
    CRON
    QUEUE
    // Software
    APPLICATION
    MODULE
    CLASS
    FUNCTION
    VARIABLE
    BRANCH
    // Data
    DATABASE
    TABLE
    STORED_PROCEDURE
    // Interface
    EXTERNAL_API
    ENDPOINT
    WEBHOOK
    // Messaging
    TOPIC
    CONSUMER
    PRODUCER
}

// A Spec's source format â€” selects which parser materializes derived child
// Components from `source` (#64). OPENAPI / ASYNCAPI / GRAPHQL / SQL_DDL /
// TS_SIGNATURE each have a bounded parser; CUSTOM is hand-authored prose (no
// parser). Which kinds a Component is OFFERED is presentation-only, keyed by
// NodeKind (ADR-0019 precedent: affinity ranks, never constrains) (CONTEXT.md
// "Spec"; ADR-0011, ADR-0025). Renamed from `FlowSpecKind` with the Flow
// model's retirement (#62 / ADR-0030).
enum SpecKind {
    OPENAPI
    ASYNCAPI
    TS_SIGNATURE
    GRAPHQL
    SQL_DDL
    CUSTOM
}

// A Connection's type, stored on its Edge as `interaction` (CONTEXT.md
// "Interaction"; ADR-0027). Five values: a default undirected ASSOCIATION plus
// four directional interactions describing, relative to the Edge's `source`
// endpoint, how it participates â€” the verb from which a Connection's arrowheads
// are DERIVED together with draw order (rendering lands in #65):
//   ASSOCIATION â€” a plain undirected relationship; no arrowheads (the default)
//   REQUEST     â€” source is called in request/response â†’ arrow at target
//   PUSH        â€” source emits unprompted (SSE, webhook out) â†’ arrow at target
//   SUBSCRIBE   â€” source consumes an external stream/feed â†’ arrow at source
//   DUPLEX      â€” source both sends and receives (WebSocket) â†’ arrows both ends
// Renamed from `FlowInteraction` and gained ASSOCIATION with the Flow model's
// retirement (#62 / ADR-0027, superseding ADR-0023).
enum Interaction {
    ASSOCIATION
    REQUEST
    PUSH
    SUBSCRIBE
    DUPLEX
}

// The data-model representation of a Component (see CONTEXT.md "Component / Node
// split"); never surfaced to users by this name. Nests via `parentId`: null is
// the Project's root Canvas, otherwise the id of the containing Component whose
// interior Canvas this Node sits on. The FK cascades are the hard-delete
// backstop only â€” the normal removal path is soft-delete via `deletedAt` (PRD).
model Node {
    id            String    @id @default(cuid())
    projectId     String
    project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    parentId      String?
    parent        Node?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
    children      Node[]    @relation("NodeChildren")
    title         String
    kind          NodeKind  @default(GENERIC)
    posX          Float     @default(0)
    posY          Float     @default(0)
    documentation String    @default("")
    metadata      Json?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    deletedAt     DateTime?
    // Batch id of the cascading soft-delete that removed this row (null when
    // live). One `deleteNode` stamps one id across the deleted Component, its
    // subtree, and every swept Edge; `restoreNode` clears `deletedAt` + this id
    // for exactly the rows bearing it, so undo restores that operation's set and
    // nothing else (CONTEXT.md "Deletion id"; ADR-0008). A lone `deleteEdge`
    // sets `deletedAt` with NO `deletionId`.
    deletionId    String?

    // Generated-component provenance (CONTEXT.md "Spec"; #64). A Component
    // derived from a Spec carries `sourceSpecId` (the Spec it came from) and a
    // stable `specKey` (the per-format identity the parser anchors on). #62
    // lands the columns + cascade; the generation that populates them is #64.
    sourceSpecId  String?
    spec          Spec?     @relation("SpecDerivedComponents", fields: [sourceSpecId], references: [id], onDelete: SetNull)
    specKey       String?

    // Project Portal (#119): when set, this Component is a live POINTER into
    // another Project â€” descending into it crosses a project boundary and renders
    // the embedded Project's content, re-gated per-actor at crossing time. A
    // nullable FK (not a NodeKind value â€” ADR-0018 keeps kind cosmetic; presence
    // of this FK is the behavioral discriminator). `onDelete: SetNull` so deleting
    // the embedded Project leaves the portal Component a harmless dangling shell
    // (it resolves no interior) rather than cascading into the host's graph.
    embeddedProjectId String?
    embeddedProject   Project? @relation("EmbeddedProjects", fields: [embeddedProjectId], references: [id], onDelete: SetNull)

    // An Edge references its endpoints by `sourceId`/`targetId`; two relations
    // to one model force Prisma's named-relation disambiguation (ADR-0005). An
    // Edge no longer stores a Canvas scope â€” scope is derived from endpoint
    // ancestry (#63 / ADR-0028).
    outgoingEdges Edge[]    @relation("EdgesFromNode")
    incomingEdges Edge[]    @relation("EdgesToNode")

    // The imported contracts owned by this Component. At most ONE is live; the
    // rest are tombstones (soft-delete + undo). Live-only 1:1 is enforced by the
    // partial unique index `idx_spec_owner_live` (WHERE "deletedAt" IS NULL) â€”
    // not a plain `@unique`, which Prisma would model as an all-rows constraint
    // and so block re-attaching a Spec while an old tombstone survives. Renamed
    // from `flowSpec` with the Flow model's retirement (#62).
    ownedSpecs Spec[] @relation("SpecOnNode")

    // Trace points referencing this Component (#59). The FK cascade is the
    // hard-delete backstop only â€” the normal removal path is the Node soft-delete,
    // which the Trace service filters at read time so a point to a soft-deleted
    // Component is ignored (ADR-0035).
    tracePoints TracePoint[] @relation("NodeTracePoints")

    // Per-scope boundary-proxy placements (#91 / ADR-0036). `containerPlacements`
    // are the placements ON this Component's interior Canvas (keyed by the off-scope
    // endpoint); `endpointPlacements` are the placements OF this Component as the
    // off-scope endpoint, across every scope that draws a proxy for it. Both cascade
    // on hard-delete; a placement is an adjunct view coordinate, never part of the
    // boundary proxy's derived identity (ADR-0031, preserved).
    containerPlacements BoundaryProxyPlacement[] @relation("ContainerPlacements")
    endpointPlacements  BoundaryProxyPlacement[] @relation("EndpointPlacements")

    // Cross-project Connections (#122) incident to this Node as a HOST endpoint.
    // `crossEdgesAsHost` is the Connections whose host Component IS this Node;
    // `crossEdgesAsReference` is the Connections routed THROUGH this Node as the
    // portal they cross (the `referenceNodeId`). Both cascade on hard-delete. The
    // FOREIGN endpoint carries no relation here â€” it is a loose String column, so a
    // foreign Node hard-delete never cascades into this host graph (render-time
    // liveness filtering hides any dangling foreign ref; #123 owns the sweep/dedup).
    crossEdgesAsHost      CrossProjectEdge[] @relation("CrossEdgeHostNode")
    crossEdgesAsReference CrossProjectEdge[] @relation("CrossEdgeReferenceNode")

    @@index([projectId, parentId])
    @@index([parentId])
    @@index([sourceSpecId])
    @@index([deletionId])
    @@index([embeddedProjectId])
}

// A persisted VIEW coordinate for a boundary proxy â€” where, on one scope's Canvas,
// the read-only stand-in for an off-scope Component sits (CONTEXT.md "Boundary
// proxy"; #91 / ADR-0036, builds on ADR-0031). The boundary proxy's IDENTITY stays
// fully derived from endpoint ancestry (ADR-0031 emits no proxy row); this table
// persists ONLY the drag position, joined back at read time as additive nullable
// `posX`/`posY` on each derived proxy. The natural key is `(containerNodeId,
// realEndpointId)`: the scope's Canvas (its container Component, null at the root
// scope) plus the off-scope endpoint the proxy stands in for â€” NEVER the
// per-crossing-edge `proxy_<edgeId>` id, so coalesced proxies (#90) sharing one
// `realEndpointId` resolve to ONE placement. The uniqueness over that pair is a
// hand-authored `NULLS NOT DISTINCT` index in the migration (Prisma can't express
// it, and a plain `@@unique` would treat the root-scope null `containerNodeId` as
// distinct and admit duplicate root-scope rows); see ADR-0010 / ADR-0036.
model BoundaryProxyPlacement {
    id              String   @id @default(cuid())
    // Null at the root scope (the proxy sits on the Project's root Canvas).
    containerNodeId String?
    container       Node?    @relation("ContainerPlacements", fields: [containerNodeId], references: [id], onDelete: Cascade)
    realEndpointId  String
    realEndpoint    Node     @relation("EndpointPlacements", fields: [realEndpointId], references: [id], onDelete: Cascade)
    posX            Float    @default(0)
    posY            Float    @default(0)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([containerNodeId])
}

// The data-model representation of a Connection (see CONTEXT.md "Connection /
// Edge split"); never surfaced to users by this name. A directed, typed edge
// that may link any two Components at any scope â€” same-Canvas, cross-scope, or
// lineal (ancestorâ†”descendant; ADR-0028). It stores NO Canvas scope: scope is
// derived from endpoint ancestry at read time (#63), so an Edge may freely span
// scope levels. It carries its own `interaction` (default ASSOCIATION); the
// arrowheads are DERIVED from `(interaction, source, target)` at render time
// (#65), never a stored direction. `sourceId`/`targetId` preserve draw order.
// The two invariants â€” no self-link, no duplicate ACTIVE Edge per the de-dupe
// rule â€” are primarily enforced in `connectNodes` (ADR-0028, retiring the
// same-Canvas invariant of ADR-0005).
//
// De-dupe is TWO partial unique indexes (in prisma/migrations; ADR-0010 named
// pattern, re-keyed on `projectId` now that scope is not stored), service-
// primary with the index as a TOCTOU backstop:
//   - `idx_edge_dedup` â€” directional, over `(projectId, sourceId, targetId,
//     interaction)` WHERE deletedAt IS NULL AND interaction <> 'ASSOCIATION'.
//     `interaction` is in the key, so Aâ†’B REQUEST and Aâ†’B PUSH coexist.
//   - `idx_edge_assoc_dedup` â€” ASSOCIATION-only, over `(projectId,
//     LEAST(sourceId,targetId), GREATEST(sourceId,targetId))` WHERE deletedAt
//     IS NULL AND interaction = 'ASSOCIATION', so Aâ†”B and Bâ†”A are one
//     Association. `NULLS NOT DISTINCT` is no longer needed (projectId is NOT
//     NULL, unlike the retired nullable `canvasNodeId`).
// Do NOT add a plain `@@unique` here â€” it would forbid re-creating a Connection
// after soft-delete and cannot express the unordered/partial predicates; the
// raw SQL lives in the migration. `label` is untrusted user content.
model Edge {
    id           String    @id @default(cuid())
    projectId    String
    project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    sourceId     String
    source       Node      @relation("EdgesFromNode", fields: [sourceId], references: [id], onDelete: Cascade)
    targetId     String
    target       Node      @relation("EdgesToNode", fields: [targetId], references: [id], onDelete: Cascade)
    interaction  Interaction @default(ASSOCIATION)
    label        String?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    deletedAt    DateTime?
    // Batch id of the cascading soft-delete that swept this Edge (see
    // Node.deletionId / ADR-0008). Set by `deleteNode`'s cascade across the
    // subtree. A `deleteEdge` is always a lone soft-delete â€” it sets
    // `deletedAt` with NO `deletionId` (the FlowRoute cascade is gone;
    // ADR-0030).
    deletionId   String?

    // Spec-derived Connection provenance (#76), the Edge analogue of
    // Node.sourceSpecId/specKey. A Connection materialized from a Spec (today: a
    // foreign key in a SQL DDL Spec) carries `sourceSpecId` (the Spec that
    // generated it) and a stable `specKey` (the per-FK identity the parser
    // anchors on â€” the constraint name, else a derived endpoint key). Both null
    // for a hand-drawn Connection. They let a re-parse RECONCILE the edges a Spec
    // owns â€” create new FKs, drop vanished ones â€” without disturbing user-drawn
    // Connections (ADR-0033). onDelete: SetNull so deleting the Spec orphans the
    // provenance, never the Connection.
    sourceSpecId String?
    spec         Spec?     @relation("SpecDerivedConnections", fields: [sourceSpecId], references: [id], onDelete: SetNull)
    specKey      String?

    @@index([sourceId])
    @@index([targetId])
    @@index([deletionId])
    @@index([sourceSpecId])
}

// A cross-project Connection: a host Component talks to a specific Component
// INSIDE an embedded Project (CONTEXT.md "Cross-project connection"; #122). It is
// ANCHORED IN THE HOST â€” viewed standalone, the foreign Project never shows this
// edge â€” and routes through a portal (`referenceNodeId`, the Project Portal Node
// the host crossed). A SEPARATE table from `Edge` on purpose: `Edge` (its
// `projectId`, the `idx_edge_dedup`/`idx_edge_assoc_dedup` partial indexes, and
// the `getCanvas` ancestry CTE) assumes one Project; a cross-project edge cannot
// live there without breaking all three. Render is a dedicated bounded pass in
// `getCanvas`, never the recursive CTE.
//
// The host endpoints (`hostProjectId`, `hostNodeId`, `referenceNodeId`) carry FK
// relations and cascade on hard-delete. The FOREIGN endpoint
// (`foreignProjectId` / `foreignNodeId`) is a PLAIN String with NO FK/relation:
// a foreign Project/Node hard-delete must NEVER cascade into the host graph, so
// the columns stay loose and a dangling foreign ref is hidden at render time by a
// liveness filter (the soft-delete sweep + dedup index are #123).
//
// NON-DISCLOSURE: `foreignProjectId` is the real internal Project.id of a project
// the host owner may have no grant to. It is stored here but NEVER reaches the
// client â€” `connectCrossProject` DERIVES it server-side from the portal's
// `embeddedProjectId`, and `getCanvas` drops any row whose foreign project the
// reading actor cannot re-resolve (ADR-0041 firewall, #119/#120 precedent).
//
// No dedup unique index this slice (#123). `label` is untrusted user content.
model CrossProjectEdge {
    id              String   @id @default(cuid())
    hostProjectId   String
    hostProject     Project  @relation("CrossEdgeHostProject", fields: [hostProjectId], references: [id], onDelete: Cascade)
    hostNodeId      String
    hostNode        Node     @relation("CrossEdgeHostNode", fields: [hostNodeId], references: [id], onDelete: Cascade)
    referenceNodeId String
    referenceNode   Node     @relation("CrossEdgeReferenceNode", fields: [referenceNodeId], references: [id], onDelete: Cascade)
    // PLAIN columns â€” no FK/relation (see model note): a foreign delete must never
    // cascade into the host graph.
    foreignProjectId String
    foreignNodeId    String
    interaction     Interaction @default(ASSOCIATION)
    label           String?
    deletedAt       DateTime?
    deletionId      String?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([hostProjectId])
    @@index([referenceNodeId])
    @@index([hostNodeId])
    @@index([foreignNodeId])
    @@index([deletionId])
}

// The imported contract on a Component (CONTEXT.md "Spec"; ADR-0011, ADR-0025)
// â€” an OpenAPI / AsyncAPI / TS-signature / GraphQL / SQL-DDL document, or
// hand-authored CUSTOM prose. 1:1 with a Component (`ownerNodeId @unique`):
// exactly one current Spec per Component. Renamed from `FlowSpec` with the Flow
// model's retirement (#62); where the old FlowSpec projected Flows, a Spec now
// points at derived child Components (via their `Node.sourceSpecId` +
// `Node.specKey`). `source` is UNTRUSTED user-pasted content â€” stored verbatim,
// never interpolated (prompt-injection standing note). #62 lands the renamed
// row + the cascade (`deleteNode` sweeps the owned Spec â€” ADR-0030); the
// specâ†’Component generation (parse, diff, merge) is #64.
model Spec {
    id          String     @id @default(cuid())
    projectId   String
    project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    // No `@unique`: live-only 1:1 is the partial index `idx_spec_owner_live`
    // (raw SQL â€” Prisma can't express a partial predicate), mirroring how Edge
    // de-dupe lives in partial indexes, not the schema. A plain `@unique` would
    // reserve the owner across tombstones too, blocking re-attach after undo.
    ownerNodeId String
    ownerNode   Node       @relation("SpecOnNode", fields: [ownerNodeId], references: [id], onDelete: Cascade)
    kind        SpecKind
    source      String
    parsedAt    DateTime?
    parseError  String?
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    deletedAt   DateTime?
    deletionId  String?
    // Child Components derived from this Spec (#64). The back-relation to
    // `Node.sourceSpecId`.
    derivedComponents Node[] @relation("SpecDerivedComponents")
    // Connections derived from this Spec (#76) â€” e.g. FK edges from a SQL DDL
    // Spec. The back-relation to `Edge.sourceSpecId`.
    derivedConnections Edge[] @relation("SpecDerivedConnections")

    @@index([projectId])
    @@index([deletionId])
}

// A named, saved Trace: a persisted set of trace points over a Project's graph
// (CONTEXT.md "Saved Trace"; ADR-0034, ADR-0035). Only the POINT SET persists â€”
// the on-path subgraph is recomputed on read by getTraceView, never stored.
// Soft-deletable + undoable as one batch via deletionId (ADR-0030). Authorized
// structurally through the Project's ownerId: reads are slug-bound (possession of
// the slug is the read grant, parity with getTraceView), writes are owner-only
// (assertCanWrite) (ADR-0001/0002). The live-only unique-name-per-Project rule is
// a partial unique index in the migration (raw SQL â€” Prisma can't express the
// WHERE predicate), mirroring idx_spec_owner_live (ADR-0010).
model Trace {
    id         String       @id @default(cuid())
    projectId  String
    project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
    name       String
    createdAt  DateTime     @default(now())
    updatedAt  DateTime     @updatedAt
    deletedAt  DateTime?
    deletionId String?
    points     TracePoint[]

    @@index([projectId])
    @@index([deletionId])
}

// A trace point: a Component (Node) marked into a saved Trace (CONTEXT.md
// "Trace point"). A point is a reference, never a behavior or a Component kind.
// The FK cascade to Node is the hard-delete backstop only â€” the normal removal
// path is the Node soft-delete, which the service filters at read time so a point
// to a soft-deleted Component is ignored (#59 acceptance; ADR-0035). TracePoint
// carries NO deletedAt: its lifecycle is its parent Trace's (cascade-delete on a
// Trace hard-delete; soft-delete is on the Trace). `@@unique([traceId, nodeId])`
// de-dupes a Component within a Trace â€” Prisma-expressible (no soft-delete axis),
// so no raw SQL is needed for it.
model TracePoint {
    id        String   @id @default(cuid())
    traceId   String
    trace     Trace    @relation(fields: [traceId], references: [id], onDelete: Cascade)
    nodeId    String
    node      Node     @relation("NodeTracePoints", fields: [nodeId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([traceId, nodeId])
    @@index([traceId])
    @@index([nodeId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
