# Test database for Vitest. Copy this file to ".env.test" and set DATABASE_URL.
#
# This MUST be a SEPARATE database from DATABASE_URL in .env — a different local
# database, or a dedicated Neon branch. The harness refuses to run if this URL
# resolves to the same database (host + name) as .env (see
# docs/adr/0003-vitest-test-harness-and-db-isolation.md), so a test run can
# never truncate your development data.
DATABASE_URL="postgresql://postgres:password@localhost:5432/infinite-docs-test"
